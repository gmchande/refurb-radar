# Manual environment reference only.
# Refurb Radar reads ENV directly; it does not autoload this file.

REFURB_RADAR_OPEN=1
REFURB_RADAR_BROWSER_ALERT=1
REFURB_RADAR_STATE=state/seen.json
REFURB_RADAR_CATALOG=state/catalog.json
REFURB_RADAR_EVENTS=state/events.jsonl
REFURB_RADAR_CONTROLS=state/controls.json
REFURB_RADAR_TARGETS=config/targets.json
REFURB_RADAR_CATALOG_REFRESH_INTERVAL=1800
REFURB_RADAR_REMINDER_INTERVAL=300
REFURB_RADAR_STATUS_BASE_PATH=/refurb-radar
REFURB_RADAR_STATUS_PUBLIC_URL=https://example.com/refurb-radar/

# Optional Twilio alerts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
REFURB_RADAR_ALERT_TO=
REFURB_RADAR_TWILIO_SMS=0
REFURB_RADAR_TWILIO_CALL=0

# Optional Cloudflare Access protection for the status page.
CLOUDFLARE_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CLOUDFLARE_ACCESS_AUD=your-cloudflare-access-audience
